{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cyonima IA",
  "version": "1.0.0",
  "identifier": "com.cyonima.ia-code-agent",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Cyonima IA",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/*"],
    "copyright": "© 2026 Cyonima — MIT License",
    "category": "DeveloperTool",
    "shortDescription": "Agent IA de code local, gratuit et open source",
    "longDescription": "Cyonima-ia-code-agent : agent IA multi-session, multi-modèles, multi-backends. 100% local, open source MIT. Cyonima est une marque."
  }
}